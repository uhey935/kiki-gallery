---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDateRangeJa } from "../../utils/date";

export async function getStaticPaths() {
  const exhibitions = await getCollection("exhibitions");
  const artists = await getCollection("artists");

  return exhibitions.map((exh) => {
    const artist = artists.find((a) => a.id === exh.data.artist);

    return {
      params: { slug: exh.id },
      props: { exh, artist },
    };
  });
}

const { exh, artist } = Astro.props;
if (!artist) throw new Error("Artist not found");
const artistName = artist.data.nameJa || artist.data.name;
const dateRange = formatDateRangeJa(
  exh.data.startDate,
  exh.data.endDate
);

const now = new Date();

const status =
  new Date(exh.data.startDate) > now
    ? "upcoming"
    : new Date(exh.data.endDate || exh.data.startDate) >= now
    ? "ongoing"
    : "past";
---

<Layout
  breadcrumb={[
    { label: "Exhibitions", href: "/exhibitions" },
    { label: exh.data.title, href: "#" },
  ]}
>
<script type="application/ld+json">
  {JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    name: exh.data.title,
    startDate: exh.data.startDate,
    endDate: exh.data.endDate || exh.data.startDate,
    eventStatus:
      status === "upcoming"
        ? "https://schema.org/EventScheduled"
        : status === "ongoing"
        ? "https://schema.org/EventInProgress"
        : "https://schema.org/EventCompleted",
    location: {
      "@type": "Place",
      name: exh.data.venue.name,
      url: exh.data.venue.map,
    },
    performer: {
      "@type": "Person",
      name: artistName,
    },
    url: `${Astro.site}/exhibitions/${exh.id}`,
  })}
</script>
  <!-- 作家名 -->
  <p>{artistName}</p>

  <!-- タイトル -->
  <h1>{exh.data.title}</h1>

  <!-- 開催日程 -->
  <p>
    開催日程：{dateRange} {exh.data.openTime}
  </p>

  <!-- 休廊日 -->
  {exh.data.closedDays && (
    <p>休廊日： {exh.data.closedDays}</p>
  )}

  <!-- 在廊日 -->
  {exh.data.attendance && (
    <p>
      作家在廊予定日： {exh.data.attendance}
      <small>（※変更となる場合があります）</small>
    </p>
  )}

  <!-- 会場 -->
  <p>
    会場：
    <a
      href={exh.data.venue.map}
      target="_blank"
      rel="noopener noreferrer"
    >
      {exh.data.venue.name}
    </a>
  </p>

  <!-- 本文 -->
  <article set:html={exh.body} />

  <!-- アーティスト導線 -->
  {artist && (
    <section>
      <h2>Artist</h2>
      <p>
        <a href={`/artists/${artist.id}`}>
          {artistName}
        </a>
      </p>
    </section>
  )}
</Layout>