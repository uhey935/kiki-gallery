---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDateRangeJa } from "../../utils/date";

export async function getStaticPaths() {
  const exhibitions = await getCollection("exhibitions");
  const artists = await getCollection("artists");

  return exhibitions.map((exh) => {
    const artist = artists.find((a) => a.data.slug === exh.data.artist);

    return {
      params: { slug: exh.id },
      props: { exh, artist },
    };
  });
}

const { exh, artist } = Astro.props;

const artistName = artist?.data.nameJa ?? artist?.data.name ?? "";
const dateRange = formatDateRangeJa(
  exh.data.startDate,
  exh.data.endDate
);
---

<Layout
  title={`${exh.data.title} | KiKi Gallery`}
  description={`${artistName} の展示。${dateRange}`}
  image={exh.data.image}
>
  <!-- 作家名 -->
  <p>{artistName}</p>

  <!-- タイトル -->
  <h1>{exh.data.title}</h1>

  <!-- 開催日程 -->
  <p>
    開催日程：{dateRange} {exh.data.openTime}
  </p>

  <!-- 休廊日 -->
  {exh.data.closedDays && (
    <p>休廊日： {exh.data.closedDays}</p>
  )}

  <!-- 在廊日 -->
  {exh.data.attendance && (
    <p>
      作家在廊予定日： {exh.data.attendance}
      <small>（※変更となる場合があります）</small>
    </p>
  )}

  <!-- 会場 -->
  <p>
    会場：
    <a
      href={exh.data.venue.map}
      target="_blank"
      rel="noopener noreferrer"
    >
      {exh.data.venue.name}
    </a>
  </p>

  <!-- 本文 -->
  <article set:html={exh.body} />

  <!-- アーティスト導線 -->
  {artist && (
    <section>
      <h2>Artist</h2>
      <p>
        <a href={`/artists/${artist.id}`}>
          {artistName}
        </a>
      </p>
    </section>
  )}
</Layout>