---
import ExhibitionCard from '../../components/exhibition/ExhibitionCard.astro';
import { getExhibitionStatus } from '../../utils/date';

const exhibitions = [
  {
    title: "Hiroshi Goseki Exhibition",
    slug: "hiroshi-goseki",
    image: "/images/goseki.jpg",
    startDate: "2026-03-10",
    endDate: "2026-03-25"
  },
  {
    title: "Group Exhibition",
    slug: "group-exhibition",
    image: "/images/group.jpg",
    startDate: "2025-11-02",
    endDate: "2025-11-10"
  }
];

// 🔥 ここ追加
const sortedExhibitions = exhibitions.sort((a, b) => {
  const statusOrder = {
    upcoming: 0,
    ongoing: 1,
    past: 2
  };

  const statusA = getExhibitionStatus(a.startDate, a.endDate);
  const statusB = getExhibitionStatus(b.startDate, b.endDate);

  return statusOrder[statusA] - statusOrder[statusB];
});
---

<h1>Exhibitions</h1>

<section class="exhibition-list">
  {sortedExhibitions.map((exhibition) => (
    <ExhibitionCard exhibition={exhibition} />
  ))}
</section>